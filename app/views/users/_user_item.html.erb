<div class="flex items-center gap-5">
  <!-- Avatar -->
  <div class="rounded-full w-15 h-15 overflow-hidden">
    <%= link_to link do %>
      <div class="symbol symbol-circle symbol-45px">
        <%= image_tag user.image.url, class: "w-full my-5" if user.image? %>
        <% unless user.image? %>
          <img
            class="w-full"
            src="https://ui-avatars.com/api/?background=random&rounded=true&name=<%=user.name %>+<%= user.lastname %>"
            alt="<%= user.name %>">
          >
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Details-->
  <div class="flex flex-col">
    <%= link_to user.full_name, link, class: "text-gray-800 hover:text-blue-500 mb-1 no-underline" %>
    <%= render "components/copyable", value: user.email %>
  </div>
</div>