<% @documents ||= documents.paginate(page: params[:page] || 1, per_page: params[:per_page] || 15) %>

<div id="documents-index" style="min-height: 50vh;">
  <div class="card card-body my-4">
    <div class="table-responsive">
      <table class="table table-hover table-striped gs-7">
        <thead>
          <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
            <th class="min-w-[125px]">Nombre</th>
            <th class="min-w-75px">Tipo</th>
            <th class="min-w-[125px]">Registro</th>
            <th class="text-end w-[125px]" aria-label="Acciones"></th>
          </tr>
        </thead>
        <tbody>
          <% if @documents.any? %>
            <% @documents.each do |document| %>

              <% icon, color = get_document_icon(document) %>

              <tr class="h-[60px]">
                <td>
                  <%= link_to document.name, document %>
                </td>
                <td>
                  <i class="fa-solid fa-<%= icon %> text-<%= color %> fs-1"></i>
                </td>
                <td><%= document.document_group.name %></td>
                <td><%= document.created_at.strftime("%d-%m-%Y") %></td>
                <td class="text-end pe-4">
                  <button
                    type="button"
                    class="btn btn-light btn-active-light-primary dropdown-toggle dropdown-toggle-split ms-4"
                    data-controller="dropdown"
                    data-action="click->dropdown#toggle blur->dropdown#handleBlur"
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    Acciones
                  </button>
                  <ul class="dropdown-menu">
                    <li>
                      <%= link_to "Descargar", document.file.url, download: document.name, class: "dropdown-item"%>
                    </li>
                    <li>
                      <%= link_to "Eliminar",
                        document,
                        class:'dropdown-item',
                        data: { controller: 'delete-button', delete_button_item_name_value: document.name }
                      %>
                    </li>
                  </ul>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr class="h-px">
            </tr>
            <tr>
              <td colspan="4" class="text-center text-muted">
                <em>No hay documentos</em>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @documents.exists? %>
      <%= render "components/paginator", items: @documents %>
    <% end %>
  </div>
  <%= link_to document_groups_path, class: "btn btn-link btn-color-primary" do %>
    ← Atrás
  <% end %>

</div>