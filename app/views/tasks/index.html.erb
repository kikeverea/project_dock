<% content_for :title, "Lista de tareas" %>

<% if can? :create, Task %>
  <%= link_to new_task_path,
    class: "btn btn-success w-[200px] mb-4" do
  %>
    <i class="fa fa-plus"></i> Nueva tarea
  <% end %>
<% end %>

<div class="card card-body my-2">
  <div class="table-responsive">
    <table class="table table-hover table-striped gs-7">
      <thead>
        <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0">
          <th class="min-w-[125px]">Nombre</th>
          <th class="min-w-100px">Tipo</th>
          <th class="min-w-100px">Estado</th>
          <th class="min-w-100px">Vencimiento</th>
          <th class="text-end w-[125px]" aria-label="Acciones"></th>
        </tr>
      </thead>
      <tbody>
        <% if @tasks.any? %>
          <% @tasks.each do |task| %>
            <tr class="h-[60px]">
              <td><%= task.name %></td>
              <td><%= task.task_type %></td>
              <td><%= task.status %></td>
              <td><%= task.expires_at&.strftime("%d-%m-%Y") %></td>
              <td class="text-end pe-4">
                <button
                  type="button"
                  class="btn btn-light btn-active-light-primary dropdown-toggle dropdown-toggle-split ms-4"
                  data-controller="dropdown"
                  data-action="click->dropdown#toggle blur->dropdown#handleBlur"
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  Acciones
                </button>
                <ul class="dropdown-menu">
                  <li><%= link_to "Ver", task, class: 'dropdown-item' %></li>
                  <li><%= link_to "Editar", edit_task_path(task), class: 'dropdown-item' %></li>
                  <li>
                    <%= link_to "Eliminar",
                      task,
                      class:'dropdown-item',
                      data: { controller: 'delete-button', delete_button_item_name_value: task.name }
                    %>
                  </li>
                </ul>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr class="h-px">
          </tr>
          <tr>
            <td colspan="5" class="text-center text-muted">
              <em>No hay tareas</em>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
