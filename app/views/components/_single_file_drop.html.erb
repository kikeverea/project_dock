<% id ||= "single=file-drop" %>
<% no_file_message ||= "Arrastra archivos o haz click aquí" %>
<% file_type ||= nil %>
<% form ||= nil %>
<% attribute ||= nil %>
<% value ||= nil %>
<% accepted_files ||= nil %>
<% uploaded_file ||= {} %>
<% upload_path ||= nil %>
<% tiny ||= false %>
<% icon, _color = file_type ? get_document_icon_by_type(file_type) : "file" %>
<% full_width ||= false %>
<% width_class ||= tiny ? "w-[70px]" : "#{full_width ? "w-full" : "w-[150px]"} mb-4" %>

<div id="<%= id %>">
  <div
    class="filezone <%= width_class %> flex-1 p-2 relative"
    id="<%= id ? "#{id}-file-dropzone" : "file-dropzone" %>"
    data-controller="single-file-upload"
    data-single-file-upload-url-value="<%= upload_path %>"
    data-single-file-upload-disable-auto-upload-value="true"
    data-single-file-upload-accepted-files-value="<%= accepted_files %>"
    data-single-file-upload-uploaded-file-value="<%= uploaded_file.is_a?(String) ? uploaded_file : uploaded_file&.to_json %>"
  >

    <% if form && attribute %>
      <%= form.file_field attribute,
        value: value,
        class: "hidden",
        data: { single_file_upload_target: "fileInput" }
      %>
    <% end %>

    <button
      id="remove-button"
      type="button"
      class="btn btn-flush btn-active-color-danger absolute end-0 me-2 <%= "hidden" unless uploaded_file && uploaded_file[:url] %>"
      data-single-file-upload-target="removeButton"
      data-action="single-file-upload#removeFile"
    >
      <i class="fa-solid fa-xmark text-lg"></i>
    </button>
    <div class="dz-error-mark">
      <i class="fa-solid fa-circle-xmark text-3xl text-danger opacity-75"></i>
    </div>
    <div class="dz-message needsclick">
      <i class="fa-solid fa-<%= icon %> text-2xl"></i>
      <div class="text-muted text-sm pt-1">
        <em><%= no_file_message %></em>
      </div>
    </div>
  </div>
</div>