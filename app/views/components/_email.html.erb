<div id="<%= id %>" class="card">
  <% if email %>
    <div class="card-header align-items-center">
      <label class="form-label mb-0">Asunto:</label>
      <span class="flex-grow-1 ps-8 pe-8"><%= email.subject %></span>
      <%= link_to "Editar", email_path, class: "btn btn-success" %>
    </div>
  <% end %>

  <div class="card-body">
    <% if email %>
      <%= email&.content&.html_safe %>
    <% else %>
      <em class="text-gray-700">No existe plantilla para este país</em>
      <div>
        <%= link_to "Crear plantilla →", email_path, class: "btn btn-link btn-active-color-primary" %>
      </div>
    <% end %>
  </div>
</div>