<% content_for :title, @client.name %>

<div class="card">
  <div class="card-body">
    <% if @client.logo? %>
      <%= image_tag @client.logo.url, class: "w-100 h-100" %>
    <% else %>
      <%= image_tag asset_path("avatar.svg"), class: "w-50 h-50 rounded-full"
      %>
    <% end %>
  </div>
</div>

<div class="mx-1 mt-3 mb-8">
  <%= link_to "← Ir a TODO", clients_path %> |
  <%= link_to "Editar", edit_client_path(@client) %>
</div>
